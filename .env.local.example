# Supabase — get from your project at https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service role key — server-side only, NEVER expose to the browser
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# App URL — used for email redirects and PDF links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — get an API key at https://resend.com (optional, emails are skipped if missing)
RESEND_API_KEY=re_XXXXXXXXXXXX

# Expediteur visible des factures par email (doit utiliser un domaine verifie chez Resend)
RESEND_FROM=Le Bissap Artisanal <facture@societe.lebissapartisanal.click>

# Adresse de reponse (Reply-To) — utile si l'expediteur est sur un sous-domaine
# non receptif (ex: societe.lebissapartisanal.click) et qu'on veut que les reponses
# arrivent sur le domaine racine via une redirection ImprovMX / Cloudflare / etc.
RESEND_REPLY_TO=facture@lebissapartisanal.click

# === V2 — IA via OpenRouter (optionnel) ===
# Sans cle, les features IA sont desactivees gracieusement.
# Obtenir une cle sur https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_APP_NAME=Le Bissap Artisanal
